CREATE TABLE public.Purchase Returns (
  ID bigint GENERATED ALWAYS AS IDENTITY NOT NULL,
  Time Stamp timestamp without time zone NOT NULL,
  Purchase Return No. character varying NOT NULL,
  Po No. character varying NOT NULL,
  Action Type character varying,
  Party Name character varying,
  Product Name character varying,
  Qty integer NOT NULL,
  Return Reason character varying,
  Transport character varying,
  Planned timestamp without time zone,
  Actual timestamp without time zone,
  Time Delay integer,
  Type of Transport character varying,
  Vehicle No character varying,
  Builty No character varying,
  Rate Type character varying,
  Amount numeric,
  Org. Bill No character varying,
  Lift No character varying,
  Return Qty integer,
  Photo of Loaded Material text,
  Weighslip of Material text,
  Firm Name text,
  mismatch_id text,
  CONSTRAINT Purchase Returns_pkey PRIMARY KEY (ID)
);
