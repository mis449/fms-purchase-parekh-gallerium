CREATE TABLE public.fullkittin (
  id bigint GENERATED ALWAYS AS IDENTITY NOT NULL,
  Indent No text,
  Fms Name text,
  Status text,
  Transporter Name text,
  Vehicle Number text,
  From text,
  To text,
  Material Load Details text,
  Bilty Number text,
  Rate Type text,
  Amount numeric,
  Bilty Image text,
  CONSTRAINT fullkittin_pkey PRIMARY KEY (id)
);
CREATE TABLE public.purchaser_coordinates (
  id uuid NOT NULL DEFAULT gen_random_uuid(),
  mismatch_id text,
  po_number text,
  type text CHECK (type = ANY (ARRAY['DEBIT_NOTE_VENDOR'::text, 'DEBIT_NOTE_TRANSPORTER'::text, 'PURCHASE_RETURN'::text])),
  vendor_name text,
  transporter_name text,
  material_name text,
  status text DEFAULT 'PENDING'::text CHECK (status = ANY (ARRAY['PENDING'::text, 'COORDINATED'::text])),
  coordinated_by text,
  coordinated_at timestamp with time zone,
  created_at timestamp with time zone DEFAULT now(),
  CONSTRAINT purchaser_coordinates_pkey PRIMARY KEY (id)
);